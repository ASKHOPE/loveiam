---
import '../styles/global.css';
import SpeedInsights from "@vercel/speed-insights/astro";

export interface Props {
    title?: string;
}

const { title = "Love In Action Ministries" } = Astro.props;
const { pathname } = Astro.url;

// Helper to determine if a route is active
const isActive = (route: string) => {
    if (route === '/') {
        return pathname === '/' || pathname === '/index.html';
    }
    return pathname.startsWith(route);
};
---
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>{title}</title>

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="mask-icon" href="/favicon.svg" color="#1a365d">
    <link rel="shortcut icon" href="/favicon.ico">

    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&amp;family=Inter:wght@400;500;700&amp;display=swap" rel="stylesheet"/>
</head>
<body class="bg-surface text-on-surface font-body antialiased min-h-screen flex flex-col">
    <!-- Desktop & Mobile Header -->
    <nav class="sticky top-0 z-40 bg-white dark:bg-zinc-950 border-b border-slate-200 dark:border-zinc-800 shadow-md w-full transition-all duration-300" id="top-nav">
        <div class="flex justify-between items-center px-gutter py-2.5 w-full max-w-container-max mx-auto">
            <!-- Brand Logo with Tagline on the Left -->
            <a class="flex items-center gap-3.5 group transition-transform duration-300 hover:scale-101 flex-shrink-0" href="/">
                <img src="/logo.png" alt="Love In Action Logo" class="h-18 md:h-24 w-auto object-contain bg-white rounded-lg p-2 shadow-sm border border-slate-200 transition-transform duration-500 group-hover:rotate-3" />
                <div class="flex flex-col items-start justify-center">
                    <span class="font-display text-base md:text-lg tracking-wider font-extrabold text-trust-navy dark:text-white leading-none">LOVE IN ACTION MINISTRIES, INC.</span>
                    <span class="font-body text-[10px] md:text-[11px] text-slate-gray dark:text-zinc-400 font-medium tracking-wide mt-1.5 hidden sm:block max-w-sm md:max-w-md">
                        Proclaiming the Gospel of Jesus Christ through the Tangible Acts of compassion.
                    </span>
                </div>
            </a>
            
            <!-- Navigation Links & Action Button Grouped on the Right -->
            <div class="hidden md:flex items-center gap-8">
                <ul class="flex space-x-8 items-center">
                    <li>
                        <a class={isActive('/') ? "text-trust-navy dark:text-action-gold border-b-2 border-action-gold py-1.5 font-extrabold font-display text-[14px] transition-all duration-200" : "text-slate-800 dark:text-zinc-200 border-b-2 border-transparent py-1.5 font-semibold font-display text-[14px] hover:text-trust-navy dark:hover:text-action-gold hover:border-action-gold/50 transition-all duration-200"} href="/">Home</a>
                    </li>
                    <li>
                        <a class={isActive('/about') ? "text-trust-navy dark:text-action-gold border-b-2 border-action-gold py-1.5 font-extrabold font-display text-[14px] transition-all duration-200" : "text-slate-800 dark:text-zinc-200 border-b-2 border-transparent py-1.5 font-semibold font-display text-[14px] hover:text-trust-navy dark:hover:text-action-gold hover:border-action-gold/50 transition-all duration-200"} href="/about">About Us</a>
                    </li>
                    <li>
                        <a class={isActive('/statement-of-faith') ? "text-trust-navy dark:text-action-gold border-b-2 border-action-gold py-1.5 font-extrabold font-display text-[14px] transition-all duration-200" : "text-slate-800 dark:text-zinc-200 border-b-2 border-transparent py-1.5 font-semibold font-display text-[14px] hover:text-trust-navy dark:hover:text-action-gold hover:border-action-gold/50 transition-all duration-200"} href="/statement-of-faith">Statement of Faith</a>
                    </li>
                    <li>
                        <a class={isActive('/contact') ? "text-trust-navy dark:text-action-gold border-b-2 border-action-gold py-1.5 font-extrabold font-display text-[14px] transition-all duration-200" : "text-slate-800 dark:text-zinc-200 border-b-2 border-transparent py-1.5 font-semibold font-display text-[14px] hover:text-trust-navy dark:hover:text-action-gold hover:border-action-gold/50 transition-all duration-200"} href="/contact">Contact</a>
                    </li>
                </ul>

                <a href="/contact" class="bg-action-gold text-white font-display font-bold text-[13px] px-6 py-2.5 rounded-md hover:bg-trust-navy hover:shadow-md transition-all duration-200 active:scale-95 flex-shrink-0">
                    Donate
                </a>
            </div>

            <!-- Mobile Menu Toggle -->
            <button id="menu-toggle" aria-label="Toggle Menu" class="md:hidden text-trust-navy dark:text-white p-2 focus:outline-none flex-shrink-0">
                <span class="material-symbols-outlined text-[28px] align-middle">menu</span>
            </button>
        </div>
    </nav>

    <!-- Mobile Menu Drawer -->
    <div id="mobile-drawer" class="fixed inset-0 z-50 bg-primary/50 backdrop-blur-sm transform translate-x-full transition-transform duration-300 md:hidden flex justify-end">
        <div class="w-72 bg-surface h-full p-6 shadow-2xl flex flex-col gap-6">
            <div class="flex justify-between items-center border-b border-outline-variant/30 pb-4">
                <span class="font-display text-trust-navy font-bold text-lg">Menu</span>
                <button id="close-drawer" aria-label="Close Menu" class="text-trust-navy p-1 focus:outline-none">
                    <span class="material-symbols-outlined text-[28px] align-middle">close</span>
                </button>
            </div>
            <ul class="flex flex-col gap-5">
                <li>
                    <a class={isActive('/') ? "text-trust-navy font-extrabold font-display text-base border-l-4 border-action-gold pl-3 block" : "text-slate-800 dark:text-zinc-200 font-bold font-display text-base pl-3 block hover:text-action-gold transition-colors duration-200"} href="/">Home</a>
                </li>
                <li>
                    <a class={isActive('/about') ? "text-trust-navy font-extrabold font-display text-base border-l-4 border-action-gold pl-3 block" : "text-slate-800 dark:text-zinc-200 font-bold font-display text-base pl-3 block hover:text-action-gold transition-colors duration-200"} href="/about">About Us</a>
                </li>
                <li>
                    <a class={isActive('/statement-of-faith') ? "text-trust-navy font-extrabold font-display text-base border-l-4 border-action-gold pl-3 block" : "text-slate-800 dark:text-zinc-200 font-bold font-display text-base pl-3 block hover:text-action-gold transition-colors duration-200"} href="/statement-of-faith">Statement of Faith</a>
                </li>
                <li>
                    <a class={isActive('/contact') ? "text-trust-navy font-extrabold font-display text-base border-l-4 border-action-gold pl-3 block" : "text-slate-800 dark:text-zinc-200 font-bold font-display text-base pl-3 block hover:text-action-gold transition-colors duration-200"} href="/contact">Contact</a>
                </li>
            </ul>
            <a href="/contact" class="bg-action-gold text-white font-display font-bold text-center py-3.5 rounded-md mt-auto w-full hover:bg-trust-navy transition-colors duration-200">
                Donate
            </a>
        </div>
    </div>
    
    <!-- Main Content Container with fadeIn animation -->
    <div class="animate-fade-in flex-grow flex flex-col">
        <slot />
    </div>
    
    <!-- Footer Section -->
    <footer class="w-full bg-primary py-section-padding-desktop px-gutter flex-shrink-0 mt-auto border-t border-primary-container">
        <div class="max-w-container-max mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mb-12 border-b border-primary-container/50 pb-12">
                <!-- Brand Column (Spans 7 cols on desktop) -->
                <div class="col-span-1 lg:col-span-7 flex flex-col items-start">
                    <a class="font-display text-headline-md font-bold text-white mb-4 flex items-center gap-4 group transition-transform duration-300 hover:-translate-y-1" href="/">
                        <img src="/logo.png" alt="Love In Action Logo" class="h-24 md:h-32 w-auto object-contain bg-white rounded-2xl p-2.5 shadow-md border border-white/10 transition-transform duration-500 group-hover:scale-105" />
                        <span class="leading-tight">LOVE IN ACTION MINISTRIES, INC.</span>
                    </a>
                    <p class="font-body text-body-md text-on-primary-container max-w-xl mb-8 leading-relaxed">
                        Proclaiming the Gospel of Jesus Christ<br/>through the Tangible Acts of compassion.
                    </p>
                </div>
                <!-- Quick Links & Support (Spans 5 cols on desktop) -->
                <div class="col-span-1 lg:col-span-5 flex flex-col justify-center">
                    <h4 class="font-display text-[18px] text-white font-semibold mb-4">Quick Links</h4>
                    <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-on-primary-container text-[14px] font-body mb-6">
                        <a class="hover:text-white transition-colors duration-200" href="/">Home</a>
                        <span class="text-white/20 font-light">|</span>
                        <a class="hover:text-white transition-colors duration-200" href="/about">About Us</a>
                        <span class="text-white/20 font-light">|</span>
                        <a class="hover:text-white transition-colors duration-200" href="/statement-of-faith">Ministries</a>
                        <span class="text-white/20 font-light">|</span>
                        <a class="hover:text-white transition-colors duration-200" href="/">Projects</a>
                        <span class="text-white/20 font-light">|</span>
                        <a class="hover:text-white transition-colors duration-200" href="/contact">Donate</a>
                        <span class="text-white/20 font-light">|</span>
                        <a class="hover:text-white transition-colors duration-200" href="/contact">Contact</a>
                    </div>
                    <div class="text-[13px] font-body text-on-primary-container/85">
                        <a class="hover:text-white underline transition-colors duration-200" href="/privacy-policy">Privacy &amp; Non-Discrimination Policy</a>
                    </div>
                </div>
            </div>
            
            <!-- Bottom Bar -->
            <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left">
                <p class="font-display text-[11px] text-on-primary-container">
                    © Copyright 2026 LOVE IN ACTION MINISTRIES, INC. (EIN: 30-1496948) All Rights Reserved. Registered 501(c)(3) Non-Profit. <a href="/privacy-policy" class="hover:text-action-gold underline ml-1">Privacy &amp; Non-Discrimination Policies</a>. Images courtesy of <a href="https://www.pexels.com" target="_blank" rel="noopener noreferrer" class="hover:text-action-gold underline transition-colors">Pexels</a>.
                </p>
                <!-- Social Icons -->
                <div class="flex space-x-4">
                    <a aria-label="Facebook" class="text-on-primary-container hover:text-action-gold transition-colors" href="https://www.facebook.com" target="_blank" rel="noopener noreferrer">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">face_nod</span>
                    </a>
                    <a aria-label="Instagram" class="text-on-primary-container hover:text-action-gold transition-colors" href="https://www.instagram.com/love_in_action_ministries_inc" target="_blank" rel="noopener noreferrer">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">photo_camera</span>
                    </a>
                    <a aria-label="Email" class="text-on-primary-container hover:text-action-gold transition-colors" href="mailto:info@loveiam.us">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">mail</span>
                    </a>
                </div>
            </div>
        </div>
    </footer>
    
    <script>
        // Initialize Vercel Web Analytics
        import { inject } from '@vercel/analytics';
        inject();

        // Simple script to add shadow to nav on scroll
        const nav = document.getElementById('top-nav');
        window.addEventListener('scroll', () => {
            if (nav) {
                if (window.scrollY > 10) {
                    nav.classList.add('shadow-md');
                    nav.classList.remove('shadow-sm');
                } else {
                    nav.classList.add('shadow-sm');
                    nav.classList.remove('shadow-md');
                }
            }
        });

        // Mobile drawer toggling (Typesafe null-safe event handlers)
        const menuToggle = document.getElementById('menu-toggle');
        const closeDrawer = document.getElementById('close-drawer');
        const drawer = document.getElementById('mobile-drawer');

        if (menuToggle && drawer) {
            menuToggle.addEventListener('click', () => {
                drawer.classList.remove('translate-x-full');
            });
        }

        if (closeDrawer && drawer) {
            closeDrawer.addEventListener('click', () => {
                drawer.classList.add('translate-x-full');
            });
        }
    </script>
    <style is:global>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
    </style>
    <SpeedInsights />
</body>
</html>
