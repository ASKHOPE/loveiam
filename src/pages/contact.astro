---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | Love In Action Ministries">
    <main class="flex-grow animate-fade-in">
        <!-- Hero Section -->
        <section class="relative w-full h-[360px] flex items-center justify-center bg-trust-navy text-white overflow-hidden">
            <div class="absolute inset-0 bg-cover bg-center opacity-30" style="background-image: url('/images/contact_hero.jpg')"></div>
            <div class="relative z-10 text-center px-gutter">
                <span class="font-display text-action-gold tracking-widest text-[12px] font-bold uppercase block mb-3">Get In Touch</span>
                <h1 class="font-display text-display-lg-mobile md:text-display-lg mb-4 text-white drop-shadow-md font-bold leading-tight">Contact Us</h1>
                <p class="font-body text-body-lg max-w-2xl mx-auto text-warm-glow opacity-90 leading-relaxed">We'd love to hear from you. Reach out to learn more about our ministries, volunteer opportunities, or how you can partner with us.</p>
            </div>
        </section>

        <!-- Contact Content -->
        <section class="py-section-padding-desktop px-gutter max-w-container-max mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
                <!-- Contact Info Cards (Bento style) -->
                <div class="flex flex-col gap-8">
                    <!-- Office Card & Map side by side -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="bg-white p-8 rounded-xl shadow-sm border border-outline-variant/30 flex flex-col gap-6 justify-between">
                            <div>
                                <h2 class="font-display text-headline-sm text-trust-navy border-b border-outline-variant/30 pb-4 font-bold">Get In Touch</h2>
                                
                                <div class="flex flex-col gap-4 text-body-md text-slate-gray leading-relaxed mt-4">
                                    <div>
                                        <p class="font-display font-extrabold text-trust-navy text-[16px] mb-1">LOVE IN ACTION MINISTRIES, INC.</p>
                                        <p>16192 Coastal Hwy.</p>
                                        <p>Lewes, DE 19958</p>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="border-t border-outline-variant/30 pt-4 w-full flex flex-col gap-3">
                                <a class="hover:text-action-gold text-trust-navy font-semibold transition-colors flex items-center gap-3.5 group/link text-body-md" href="mailto:info@loveiam.us">
                                    <span class="material-symbols-outlined text-[20px] text-trust-navy group-hover/link:text-action-gold transition-colors">mail</span>
                                    info@loveiam.us
                                </a>
                                <a class="hover:text-action-gold text-trust-navy font-semibold transition-colors flex items-center gap-3.5 group/link text-body-md" href="https://www.loveiam.us" target="_blank" rel="noopener noreferrer">
                                    <span class="material-symbols-outlined text-[20px] text-trust-navy group-hover/link:text-action-gold transition-colors">language</span>
                                    www.loveiam.us
                                </a>
                            </div>
                        </div>

                        <!-- Smaller Google Map Card -->
                        <div class="rounded-xl overflow-hidden shadow-sm border border-outline-variant/30 min-h-[300px] md:min-h-full relative bg-surface-container-low">
                            <iframe 
                                class="absolute inset-0 w-full h-full border-0" 
                                src="https://maps.google.com/maps?q=16192%20Coastal%20Hwy,%20Lewes,%20DE%2019958&t=&z=14&ie=UTF8&iwloc=&output=embed" 
                                allowfullscreen="" 
                                loading="lazy" 
                                referrerpolicy="no-referrer-when-downgrade"
                                title="Google Maps Location for LOVE IN ACTION MINISTRIES, INC."
                            ></iframe>
                        </div>
                    </div>

                    <!-- Social Follow -->
                    <div class="bg-trust-navy text-white p-8 rounded-xl shadow-lg flex flex-col gap-6 relative overflow-hidden group">
                        <div class="absolute -right-10 -top-10 w-40 h-40 bg-action-gold rounded-full opacity-10 blur-2xl pointer-events-none transition-transform duration-500 group-hover:scale-110"></div>
                        <h2 class="font-display text-headline-sm md:text-headline-md text-white border-b border-white/10 pb-4 relative z-10 font-bold">Follow Us</h2>
                        <div class="flex flex-col gap-4 relative z-10">
                            <!-- Social item grid/list -->
                            <div class="grid grid-cols-2 gap-4">
                                <a aria-label="Facebook" class="flex items-center gap-3 border border-white/20 rounded-md p-3.5 hover:bg-white hover:text-trust-navy transition-all duration-300" href="https://www.facebook.com" target="_blank" rel="noopener noreferrer">
                                    <span class="material-symbols-outlined text-[20px]">face_nod</span>
                                    <span class="font-display text-xs font-bold uppercase">Facebook</span>
                                </a>
                                <a aria-label="Instagram" class="flex items-center gap-3 border border-white/20 rounded-md p-3.5 hover:bg-white hover:text-trust-navy transition-all duration-300" href="https://www.instagram.com/love_in_action_ministries_inc" target="_blank" rel="noopener noreferrer">
                                    <span class="material-symbols-outlined text-[20px]">photo_camera</span>
                                    <span class="font-display text-xs font-bold uppercase">Instagram</span>
                                </a>
                                <a aria-label="YouTube" class="flex items-center gap-3 border border-white/20 rounded-md p-3.5 hover:bg-white hover:text-trust-navy transition-all duration-300" href="https://www.youtube.com" target="_blank" rel="noopener noreferrer">
                                    <span class="material-symbols-outlined text-[20px]">smart_display</span>
                                    <span class="font-display text-xs font-bold uppercase">YouTube</span>
                                </a>
                                <a aria-label="LinkedIn" class="flex items-center gap-3 border border-white/20 rounded-md p-3.5 hover:bg-white hover:text-trust-navy transition-all duration-300" href="https://www.linkedin.com" target="_blank" rel="noopener noreferrer">
                                    <span class="material-symbols-outlined text-[20px]">work</span>
                                    <span class="font-display text-xs font-bold uppercase">LinkedIn</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Contact Form -->
                <div class="bg-white p-8 rounded-xl shadow-sm border border-outline-variant/30 h-full">
                    <h2 class="font-display text-headline-sm md:text-headline-md text-trust-navy mb-6 font-bold">Send a Message</h2>
                    <form class="flex flex-col gap-6" onsubmit="event.preventDefault(); alert('Thank you! Your message has been submitted.');">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="flex flex-col gap-2">
                                <label class="font-display text-[11px] font-bold text-slate-gray tracking-wider uppercase" for="firstName">First Name</label>
                                <input class="border border-outline-variant rounded-md px-4 py-3 font-body text-body-md focus:outline-none focus:border-trust-navy focus:ring-1 focus:ring-trust-navy transition-colors bg-surface-bright" id="firstName" placeholder="Jane" type="text" required/>
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="font-display text-[11px] font-bold text-slate-gray tracking-wider uppercase" for="lastName">Last Name</label>
                                <input class="border border-outline-variant rounded-md px-4 py-3 font-body text-body-md focus:outline-none focus:border-trust-navy focus:ring-1 focus:ring-trust-navy transition-colors bg-surface-bright" id="lastName" placeholder="Doe" type="text" required/>
                            </div>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="font-display text-[11px] font-bold text-slate-gray tracking-wider uppercase" for="email">Email Address</label>
                            <input class="border border-outline-variant rounded-md px-4 py-3 font-body text-body-md focus:outline-none focus:border-trust-navy focus:ring-1 focus:ring-trust-navy transition-colors bg-surface-bright" id="email" placeholder="jane@example.com" type="email" required/>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="font-display text-[11px] font-bold text-slate-gray tracking-wider uppercase" for="subject">Subject</label>
                            <input class="border border-outline-variant rounded-md px-4 py-3 font-body text-body-md focus:outline-none focus:border-trust-navy focus:ring-1 focus:ring-trust-navy transition-colors bg-surface-bright" id="subject" placeholder="How can we help?" type="text" required/>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="font-display text-[11px] font-bold text-slate-gray tracking-wider uppercase" for="message">Message</label>
                            <textarea class="border border-outline-variant rounded-md px-4 py-3 font-body text-body-md focus:outline-none focus:border-trust-navy focus:ring-1 focus:ring-trust-navy transition-colors bg-surface-bright resize-none" id="message" placeholder="Write your message here..." rows="5" required></textarea>
                        </div>
                        <button class="bg-trust-navy text-white font-display font-bold text-[13px] px-8 py-4 rounded-md hover:bg-action-gold hover:text-white transition-all shadow-md mt-4 hover:-translate-y-0.5 self-start" type="submit">
                            Send Message
                        </button>
                    </form>
                </div>
            </div>
        </section>
    </main>
</Layout>
