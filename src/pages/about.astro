---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us | Love In Action Ministries">
    <main class="flex-grow animate-fade-in">
        <!-- Hero Section -->
        <section class="relative w-full min-h-[500px] flex items-center justify-center overflow-hidden bg-trust-navy py-16">
            <!-- Background Image with Overlay -->
            <div class="absolute inset-0 z-0">
                <img class="w-full h-full object-cover object-center opacity-40 mix-blend-overlay" src="/images/salvation.jpg" alt="Dramatic sun rays parting through clouds and shining down"/>
                <div class="absolute inset-0 bg-gradient-to-t from-trust-navy via-trust-navy/80 to-transparent"></div>
            </div>
            
            <div class="relative z-10 w-full max-w-container-max mx-auto px-gutter text-center">
                <div class="inline-flex items-center justify-center space-x-2 bg-white/10 backdrop-blur-md border border-white/20 rounded-full px-4 py-1.5 mb-8 animate-fade-in-up">
                    <span class="material-symbols-outlined text-action-gold text-sm" style="font-variation-settings: 'FILL' 1;">lightbulb</span>
                    <span class="text-white font-display text-[10px] tracking-wider font-bold uppercase">Our Mission</span>
                </div>
                <h1 class="font-display text-display-lg-mobile md:text-display-lg text-white mb-6 max-w-4xl mx-auto drop-shadow-md leading-tight">
                    About Us
                </h1>
                <p class="font-body text-body-lg text-white/90 max-w-4xl mx-auto leading-relaxed">
                    LOVE IN ACTION MINISTRIES, INC. is a non-profit and non-denominational Christian faith-based organization<br/>established to proclaim the Gospel of Jesus Christ<br/>through the Tangible Acts of compassion.
                </p>
            </div>
        </section>

        <!-- Quote Section -->
        <section class="py-section-padding-mobile md:py-section-padding-desktop px-gutter bg-warm-glow relative">
            <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-action-gold/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-action-gold/30 to-transparent"></div>
            <div class="max-w-4xl mx-auto text-center">
                <span class="material-symbols-outlined text-6xl text-action-gold/40 mb-6 block mx-auto" style="font-variation-settings: 'FILL' 1;">format_quote</span>
                <blockquote class="font-display text-headline-sm md:text-headline-md text-trust-navy italic mb-8 relative z-10 leading-relaxed">
                    “Let us not love in word or speech, but in action and in truth.”
                </blockquote>
                <cite class="font-display text-[12px] font-bold text-slate-gray tracking-widest uppercase flex items-center justify-center gap-2 before:content-[''] before:w-8 before:h-px before:bg-action-gold after:content-[''] after:w-8 after:h-px after:bg-action-gold">
                    1 John 3:18
                </cite>
            </div>
        </section>

        <!-- Identity & Commitment Section (Bento Grid Layout) -->
        <section class="py-section-padding-mobile md:py-section-padding-desktop px-gutter bg-surface">
            <div class="max-w-container-max mx-auto">
                <div class="text-center mb-16">
                    <span class="font-display text-action-gold tracking-widest text-[12px] font-bold uppercase block mb-3">Our Core Values</span>
                    <h2 class="font-display text-headline-md text-primary font-bold leading-tight mb-4">Our Identity &amp; Commitment</h2>
                    <p class="font-body text-body-md text-slate-gray max-w-2xl mx-auto">We are driven by a steadfast faith to serve communities with empathy and proactive energy.</p>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                    <!-- Main Identity Card (Spans 8 cols on desktop) -->
                    <div class="md:col-span-8 bg-white border border-outline-variant/30 rounded-xl overflow-hidden group shadow-sm">
                        <div class="h-64 md:h-80 relative overflow-hidden">
                            <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" src="/images/fellowship.jpg" alt="Christian community fellowship sharing a meal"/>
                            <div class="absolute inset-0 bg-gradient-to-t from-trust-navy/90 to-transparent"></div>
                            <div class="absolute bottom-6 left-6 right-6">
                                <h3 class="font-display text-headline-sm text-white font-bold flex items-center gap-2">
                                    <span class="material-symbols-outlined text-action-gold text-2xl" style="font-variation-settings: 'FILL' 1;">diversity_1</span>
                                    Rooted in Faith, Driven by Action
                                </h3>
                            </div>
                        </div>
                        <div class="p-8">
                            <p class="font-body text-body-md text-slate-gray leading-relaxed mb-6">
                                LOVE IN ACTION MINISTRIES, INC. is founded on the core belief that true compassion requires movement. We are not merely observers of hardship; we are active participants in bringing relief, hope, and the message of grace to those who need it most. Our non-denominational approach allows us to partner across boundaries to maximize our impact.
                            </p>
                            <a class="inline-flex items-center font-display font-bold text-[13px] text-trust-navy hover:text-action-gold transition-all duration-300 gap-2 hover:gap-3" href="/statement-of-faith">
                                Learn about our approach <span class="material-symbols-outlined text-sm">arrow_forward</span>
                            </a>
                        </div>
                    </div>
                    
                    <!-- Commitment Card (Spans 4 cols on desktop) -->
                    <div class="md:col-span-4 bg-trust-navy text-white rounded-xl p-8 relative overflow-hidden shadow-lg flex flex-col justify-between group">
                        <span class="material-symbols-outlined absolute -bottom-10 -right-10 text-[180px] text-white/5 pointer-events-none transform -rotate-12 group-hover:scale-105 transition-transform duration-500" style="font-variation-settings: 'FILL' 1;">volunteer_activism</span>
                        <div>
                            <div class="w-12 h-12 rounded-full bg-action-gold/20 flex items-center justify-center mb-6">
                                <span class="material-symbols-outlined text-action-gold" style="font-variation-settings: 'FILL' 1;">handshake</span>
                            </div>
                            <h3 class="font-display text-headline-sm font-bold mb-4">Unwavering Commitment</h3>
                            <p class="font-body text-body-md text-white/80 leading-relaxed mb-6">
                                We are steadfast in our mission to serve the vulnerable. Our commitment is not seasonal but enduring, focusing on sustainable community support and immediate relief during crises.
                            </p>
                        </div>
                        <ul class="space-y-4 font-body text-sm text-white/80 border-t border-white/10 pt-6">
                            <li class="flex items-start gap-3">
                                <span class="material-symbols-outlined text-action-gold text-xl mt-0.5" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                                <span>Immediate Crisis Relief</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="material-symbols-outlined text-action-gold text-xl mt-0.5" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                                <span>Sustainable Community Support</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="material-symbols-outlined text-action-gold text-xl mt-0.5" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                                <span>Spiritual Guidance &amp; Care</span>
                            </li>
                        </ul>
                    </div>
                    
                    <!-- Small Info Cards (Span 4 cols each) -->
                    <div class="md:col-span-4 bg-white border border-outline-variant/30 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
                        <span class="material-symbols-outlined text-trust-navy text-3xl mb-4" style="font-variation-settings: 'FILL' 1;">public</span>
                        <h4 class="font-display font-bold text-trust-navy mb-2 text-xl">Global Reach</h4>
                        <p class="font-body text-body-md text-slate-gray leading-relaxed">Extending our hands across borders to deliver tangible compassion wherever the need arises.</p>
                    </div>
                    <div class="md:col-span-4 bg-white border border-outline-variant/30 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
                        <span class="material-symbols-outlined text-trust-navy text-3xl mb-4" style="font-variation-settings: 'FILL' 1;">groups</span>
                        <h4 class="font-display font-bold text-trust-navy mb-2 text-xl">Community Focused</h4>
                        <p class="font-body text-body-md text-slate-gray leading-relaxed">Building strong, resilient communities through education, support, and shared faith.</p>
                    </div>
                    <a href="/contact" class="md:col-span-4 bg-warm-glow border border-action-gold/20 rounded-xl p-6 shadow-sm flex flex-col justify-center items-center text-center group cursor-pointer hover:bg-action-gold/10 transition-colors">
                        <span class="material-symbols-outlined text-action-gold text-4xl mb-3 group-hover:-translate-y-1 transition-transform">volunteer_activism</span>
                        <h4 class="font-display font-bold text-trust-navy mb-2 text-xl">Join Our Mission</h4>
                        <p class="font-display text-[12px] text-action-gold font-bold uppercase tracking-wider">Get Involved Today</p>
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>
